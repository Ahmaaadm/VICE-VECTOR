# Copy this file to .env and fill in your own values.
# Real OS environment variables override anything set here.

# Google Gemini — required. Get a key at https://aistudio.google.com/api-keys
GEMINI_API_KEY=

# Postgres connection (ASP.NET Core maps double-underscore to nested config keys)
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=gta6_rag;Username=postgres;Password=postgres

# Ollama (local embedding service)
Ollama__BaseUrl=http://localhost:11434
Ollama__EmbedModel=nomic-embed-text

# Gemini model + endpoint
Gemini__BaseUrl=https://generativelanguage.googleapis.com
Gemini__Model=gemini-flash-latest
